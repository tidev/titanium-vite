{
  "name": "@titanium-sdk/vite-plugin-titanium",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .turbo node_modules",
    "dev": "tsc",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "titanium",
    "vite-plugin"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@titanium-sdk/polyfills": "workspace:*",
    "@titanium-sdk/vite-plugin-titanium-alloy": "workspace:*",
    "@titanium-sdk/vite-titanium-environment": "workspace:*",
    "@titanium-sdk/vite-utils": "workspace:*",
    "debug": "^4.4.0",
    "fast-xml-parser": "^5.0.8",
    "rolldown": "^1.0.0-rc.18",
    "tinyglobby": "^0.2.13",
    "tiws": "^1.0.1",
    "vite-plugin-static-copy": "^3.3.0"
  },
  "devDependencies": {
    "@titanium-sdk/eslint-config": "workspace:*",
    "@titanium-sdk/prettier-config": "workspace:*",
    "@titanium-sdk/tsconfig": "workspace:*",
    "@types/connect": "^3.4.38",
    "@types/debug": "^4.1.12",
    "@types/node": "catalog:",
    "dotenv-cli": "^7.4.2",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@titanium-sdk/eslint-config/base"
    ]
  },
  "prettier": "@titanium-sdk/prettier-config"
}
