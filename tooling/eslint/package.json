{
  "name": "@titanium-sdk/eslint-config",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "exports": {
    "./base": "./base.js"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/compat": "^1.2.3",
    "@eslint/js": "^9.12.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-turbo": "^2.3.1",
    "typescript-eslint": "8.15.0"
  },
  "devDependencies": {
    "@titanium-sdk/prettier-config": "workspace:*",
    "@titanium-sdk/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@titanium-sdk/prettier-config"
}
